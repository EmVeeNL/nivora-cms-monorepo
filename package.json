{
  "name": "nivora-cms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @nivora-cms/app-admin dev",
    "build": "pnpm --filter @nivora-cms/app-admin build",
    "deploy": "pnpm --filter @nivora-cms/app-admin deploy",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run --passWithNoTests",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}